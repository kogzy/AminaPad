---
import fs from 'node:fs';
import yaml from 'js-yaml';
import Base from '../layouts/Base.astro';

const settings = yaml.load(fs.readFileSync('src/content/settings.yaml', 'utf8'));

const postFiles = import.meta.glob('../content/blog/*.md', { eager: true });

function getReadingTime(content) {
  var words = content ? content.split(/\s+/).length : 0;
  var minutes = Math.ceil(words / 200);
  return minutes + ' min read';
}

function getSlugFromPath(filePath) {
  var parts = filePath.split('/');
  var fileName = parts[parts.length - 1];
  return fileName.replace('.md', '');
}

var allPosts = [];
for (var path of Object.keys(postFiles)) {
  var mod = postFiles[path];
  if (mod.frontmatter && !mod.frontmatter.draft && !mod.frontmatter.archived) {
    allPosts.push({
      frontmatter: mod.frontmatter,
      slug: getSlugFromPath(path),
      readingTime: getReadingTime(mod.rawContent ? mod.rawContent() : ''),
    });
  }
}

allPosts.sort(function(a, b) {
  return new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime();
});

var featuredPosts = allPosts.filter(function(p) { return p.frontmatter.featured; });
var recentPosts = allPosts.filter(function(p) { return !p.frontmatter.featured; });

var postsPerPage = settings.posts_per_page || 8;
var displayPosts = featuredPosts.concat(recentPosts).slice(0, postsPerPage);
var showReadingTime = settings.show_reading_time !== false;
var homepageImage = settings.homepage_image || settings.author_photo || '';
var showHomepageImage = settings.show_homepage_image && homepageImage;
var showSocialHomepage = settings.show_social_homepage && settings.social_links && settings.social_links.length > 0;
var showDate = settings.show_date !== false;

function formatDate(dateStr) {
  var d = new Date(dateStr);
  return d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
---
<Base>
  <section class="home-hero">
    {showHomepageImage && (
      <img class="home-hero-image" src={homepageImage} alt={settings.author_name || 'Author'} />
    )}
    <h1>{settings.site_title}</h1>
    {settings.site_tagline && (
      <p class="tagline">{settings.site_tagline}</p>
    )}
    {showSocialHomepage && (
      <div class="home-social">
        {settings.social_links.map((link) => (
          <a href={link.url} target="_blank" rel="noopener noreferrer">{link.platform}</a>
        ))}
      </div>
    )}
  </section>

  {featuredPosts.length > 0 && (
    <section>
      <h2 class="section-label">Featured</h2>
      <div class="posts-grid">
        {featuredPosts.map((post) => (
          <article class="post-card">
            {post.frontmatter.featured_image && (
              <img
                class="post-card-image"
                src={post.frontmatter.featured_image}
                alt={post.frontmatter.featured_image_alt || post.frontmatter.title}
                loading="lazy"
              />
            )}
            <div class="post-card-body">
              <div class="post-card-meta">
                <span class="featured-badge">Featured</span>
                {(showDate || showReadingTime) && (
                  <span class="meta-dot">&middot;</span>
                )}
                {showDate && (
                  <time>{formatDate(post.frontmatter.date)}</time>
                )}
                {showReadingTime && (
                  <span class="meta-dot">&middot;</span>
                )}
                {showReadingTime && (
                  <span class="reading-time">{post.readingTime}</span>
                )}
              </div>
              <h2><a href={'/blog/' + post.slug + '/'}>{post.frontmatter.title}</a></h2>
              <p class="excerpt">{post.frontmatter.description}</p>
              {post.frontmatter.tags && post.frontmatter.tags.length > 0 && (
                <div class="post-card-tags">
                  {post.frontmatter.tags.map((tag) => (
                    <a class="tag" href={'/tags/' + tag.toLowerCase() + '/'}>{tag}</a>
                  ))}
                </div>
              )}
            </div>
          </article>
        ))}
      </div>
    </section>
  )}

  <section>
    <h2 class="section-label">Recent Posts</h2>
    {recentPosts.length > 0 ? (
      <div class="posts-grid">
        {recentPosts.slice(0, postsPerPage).map((post) => (
          <article class="post-card">
            {post.frontmatter.featured_image && (
              <img
                class="post-card-image"
                src={post.frontmatter.featured_image}
                alt={post.frontmatter.featured_image_alt || post.frontmatter.title}
                loading="lazy"
              />
            )}
            <div class="post-card-body">
              <div class="post-card-meta">
                {showDate && (
                  <time>{formatDate(post.frontmatter.date)}</time>
                )}
                {showDate && showReadingTime && (
                  <span class="meta-dot">&middot;</span>
                )}
                {showReadingTime && (
                  <span class="reading-time">{post.readingTime}</span>
                )}
              </div>
              <h2><a href={'/blog/' + post.slug + '/'}>{post.frontmatter.title}</a></h2>
              <p class="excerpt">{post.frontmatter.description}</p>
              {post.frontmatter.tags && post.frontmatter.tags.length > 0 && (
                <div class="post-card-tags">
                  {post.frontmatter.tags.map((tag) => (
                    <a class="tag" href={'/tags/' + tag.toLowerCase() + '/'}>{tag}</a>
                  ))}
                </div>
              )}
            </div>
          </article>
        ))}
      </div>
    ) : (
      <p>No posts yet. Check back soon!</p>
    )}
  </section>

  {allPosts.length > postsPerPage && (
    <div class="view-all">
      <a href="/blog/">View all posts</a>
    </div>
  )}
</Base>
